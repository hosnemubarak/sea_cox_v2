# =============================================================================
# Sea Cox's Fire & Safety LLC — Environment Variables
# =============================================================================
# Copy this file to .env and update the values for your environment
#   cp .env.example .env
# =============================================================================

# ── Django Core ──────────────────────────────────────────────────────
# SECURITY WARNING: Change this to a random string in production!
# Generate one: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-seacoxv2-static-site-key-change-in-production

# SECURITY WARNING: Never run with DEBUG=True in production!
DEBUG=False

# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=localhost,127.0.0.1,seacoxsfire.com,www.seacoxsfire.com

# ── Logging ──────────────────────────────────────────────────────────
# Max log file size in bytes (default: 5MB)
LOG_MAX_BYTES=5242880

# Number of backup log files to keep (default: 10)
LOG_BACKUP_COUNT=10